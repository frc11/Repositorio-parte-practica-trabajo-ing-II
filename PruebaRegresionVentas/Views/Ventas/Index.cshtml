@model VentasVM.IndexVentasVM
@{
    ViewData["Title"] = "Listado de Ventas";
}

<div class="container-fluid">
    <div class="row col-md-12">
        <form id="filtro-form" class="row g-3 align-items-center p-3 mb-3 bg-light border rounded">
            <div class="row">
                <h2 class="col-md-4">Filtros</h2>
                <div class="col-md-4"></div>
                <div class="col-md-4">
                    <a asp-action="ResetearFiltros" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-counterclockwise"></i> Resetear Filtros
                    </a>
                </div>
            </div>
            <div class="col-xl-2 col-md-6">
                <label asp-for="FechaInicio" class="form-label">Fecha de Inicio</label>
                <input asp-for="FechaInicio" type="date" class="form-control filtro-control" />
            </div>
            <div class="col-xl-2 col-md-6">
                <label asp-for="FechaFin" class="form-label">Fecha de Fin</label>
                <input asp-for="FechaFin" type="date" class="form-control filtro-control" />
            </div>
            <div class="col-xl-2 col-md-6">
                <label asp-for="Turno" class="form-label"></label>
                <select asp-for="Turno" class="form-select filtro-control" asp-items="Html.GetEnumSelectList<VentasVM.IndexVentasVM.Turnos>()"></select>
            </div>
            <div class="col-xl-2 col-md-6">
                <label asp-for="IdMetodoPago" class="form-label"></label>
                <select asp-for="IdMetodoPago" class="form-select filtro-control filtroMetodoPago">
                    <option value="" selected>Todos</option>
                    @foreach(var metodo in Model.MetodosPago){
                        <option value="@metodo.IdMetodo">@metodo.Metodo</option>
                    }
                </select>
            </div>
            <div class="col-xl-4 col-md-6">
                <label asp-for="Busqueda" class="form-label">Buscar</label>
                <input asp-for="Busqueda" class="form-control filtro-control" placeholder="Producto o Promoción..." />
            </div>
        </form>
    </div>
    <div class="row col-md-12">
        <h1 class="col-md-4">Listado de Ventas</h1>
        <h1 class="col-md-4">Cantidad de ventas: <span id="cantidad-general-display" class="fw-bold"></span></h1>
        <h1 class="col-md-4">Total: <span id="total-general-display" class="fw-bold text-success"></span></h1>
    </div>
    <div class="row col-md-12"><hr></div>
    <div class="table-responsive row col-md-12">
        <table class="table table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th>N°</th>
                    <th>Promociones/Productos</th>
                    <th>Método de Pago</th>
                    <th>Total</th>
                    <th>Fecha y Hora</th>
                    <th>Detalle</th>
                    <th style="width: 220px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="tabla-ventas-body">
                <partial name="_VentasTabla" model="Model.Ventas" />
            </tbody>
        </table>
    </div>
</div>

<a asp-action="Alta" class="btn btn-success btn-lg btn-float">+</a>

@section Scripts {
    <script>
        $(document).ready(function () {
            function actualizarTablaVentas() {
                var data = {
                    FechaInicio: $('#FechaInicio').val(),
                    FechaFin: $('#FechaFin').val(),
                    Busqueda: $('#Busqueda').val(),
                    IdMetodoPago: $('#IdMetodoPago').val(),
                    Turno: $('#Turno').val()
                };

                $.ajax({
                    url: '@Url.Action("_BuscarVentas", "Ventas")',
                    type: 'GET',
                    data: data,
                    success: function (result) {
                        $('#tabla-ventas-body').html(result);
                        calcularYMostrarTotalGeneral();
                    },
                    error: function () {
                        alert("Error al cargar los datos. Intente nuevamente.");
                    }
                });
            }
            function calcularYMostrarTotalGeneral() {
                let totalGeneral = 0;
                let cantidadGeneral = $('#tabla-ventas-body .venta').length;
                let cantidadGeneralConYo = cantidadGeneral;
                let num = cantidadGeneralConYo;
                $('#tabla-ventas-body .venta').each(function() {
                    const metodoPago = $(this).find('.metodoPagoVenta').text().trim();
                    const textoTotal = $(this).find('.totalVenta').text();
                    const valorNumerico = parseFloat(textoTotal.replace('$', '').replace(/\./g, '').replace(',', '.')) || 0;

                    if(metodoPago === "Yo") {
                        cantidadGeneral--;
                        // NO sumamos este valor al totalGeneral
                    } else {
                        totalGeneral += valorNumerico;
                    }
                    $(this).find(".numeroVenta").text(num--);
                });
                if($('.filtroMetodoPago option:selected').select().text().trim() == "Yo"){
                    cantidadGeneral = cantidadGeneralConYo;
                }
                // 4. Formateamos el resultado y lo mostramos en el span que creamos.
                const totalFormateado = totalGeneral.toLocaleString('es-AR', { style: 'currency', currency: 'ARS' });
                $('#total-general-display').text(totalFormateado);
                $('#cantidad-general-display').text(cantidadGeneral);
            }
            // Actualizar tabla al cambiar cualquier filtro
            $('.filtro-control').on('change', function() {
                actualizarTablaVentas();
            });
            // Actualizar al escribir en el buscador
            $('#Busqueda').on('keyup', function() {
                actualizarTablaVentas();
            });
            calcularYMostrarTotalGeneral();
            actualizarTablaVentas();
        });
    </script>
}
